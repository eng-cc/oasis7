{
  "type": "object",
  "additionalProperties": false,
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entry_kind", "summary", "source_refs"],
        "properties": {
          "entry_kind": {
            "type": "string",
            "enum": ["attempt", "hypothesis", "decision", "open_question", "next_step"]
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 280
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
