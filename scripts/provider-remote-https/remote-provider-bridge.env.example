OASIS7_PROVIDER_BRIDGE_ROOT=/opt/oasis7/remote-provider-bridge/current
OASIS7_PROVIDER_BRIDGE_BIN=/opt/oasis7/remote-provider-bridge/current/target/release/oasis7_provider_local_bridge
OASIS7_PROVIDER_CLI_WRAPPER=/opt/oasis7/remote-provider-bridge/current/scripts/provider-remote-https/letai_provider_cli.py
OASIS7_PROVIDER_BRIDGE_BIND=127.0.0.1:5841
OASIS7_PROVIDER_AGENT_ID=letai-remote
OASIS7_PROVIDER_THINKING=off
OASIS7_PROVIDER_BRIDGE_AUTH_TOKEN=replace-with-random-bearer-token
OASIS7_PROVIDER_AUTH_ROUTE_MAP_PATH=
OASIS7_PROVIDER_AUTH_ROUTE_FROM_BEARER=

OASIS7_REMOTE_LLM_BASE_URL=https://api.letai.run/v1
OASIS7_REMOTE_LLM_HEALTH_URL=https://api.letai.run/v1/models
OASIS7_REMOTE_LLM_API_KEY=replace-with-letai-api-key
OASIS7_REMOTE_LLM_MODEL=replace-with-letai-model
OASIS7_REMOTE_LLM_TIMEOUT_MS=15000
OASIS7_REMOTE_LLM_MAX_OUTPUT_TOKENS=256
OASIS7_REMOTE_LLM_TEMPERATURE=0
OASIS7_REMOTE_LLM_RESPONSE_FORMAT_JSON_OBJECT=false
OASIS7_REMOTE_LLM_ROUTES_PATH=
OASIS7_REMOTE_LLM_NEWAPI_BRIDGE_STATE_PATH=
# OASIS7_REMOTE_LLM_SYSTEM_PROMPT=Optional extra system prompt prepended before the runtime prompt.
# OASIS7_REMOTE_LLM_EXTRA_HEADERS_JSON={"X-Custom-Header":"value"}

# If OASIS7_PROVIDER_AUTH_ROUTE_MAP_PATH and OASIS7_REMOTE_LLM_ROUTES_PATH are set, the bridge
# switches to per-user routing. Example auth map JSON:
# {
#   "bridge-user-token-a": "alice",
#   "bridge-user-token-b": "bob"
# }
#
# Example routes JSON:
# {
#   "alice": {
#     "api_key": "letai-token-key-for-alice",
#     "model": "gpt-5.4",
#     "base_url": "https://api.letai.run/v1"
#   },
#   "bob": {
#     "api_key": "letai-token-key-for-bob",
#     "model": "gpt-5.4",
#     "base_url": "https://api.letai.run/v1"
#   }
# }
#
# Recommended operator flow:
#   1. cp /etc/oasis7/remote-provider-auth-routes.json.example /etc/oasis7/remote-provider-auth-routes.json
#   2. cp /etc/oasis7/remote-provider-llm-routes.json.example /etc/oasis7/remote-provider-llm-routes.json
#   3. python3 scripts/provider-remote-https/manage-user-route.py upsert-user \
#        --auth-routes /etc/oasis7/remote-provider-auth-routes.json \
#        --llm-routes /etc/oasis7/remote-provider-llm-routes.json \
#        --user alice \
#        --api-key letai-token-key-for-alice \
#        --model gpt-5.4
#
# Automatic newapi mapping flow:
#   1. OASIS7_PROVIDER_AUTH_ROUTE_FROM_BEARER=true
#   2. OASIS7_REMOTE_LLM_NEWAPI_BRIDGE_STATE_PATH=/path/to/newapi-bridge-state.json
#   3. Client sends --agent-provider-auth-token <newapi_user_ref> (or bridge_user_id:<id>)
#   4. Bridge resolves bearer -> newapi bridge state -> token_key automatically
