OASIS7_NEWAPI_BRIDGE_ROOT=/opt/oasis7/newapi-bridge/current
OASIS7_NEWAPI_BRIDGE_BIN=/opt/oasis7/newapi-bridge/current/oasis7_newapi_bridge_service
OASIS7_NEWAPI_BRIDGE_BIND_ADDR=127.0.0.1:5852
OASIS7_NEWAPI_BRIDGE_STATE_PATH=/etc/oasis7/newapi-bridge/bridge-state.json
OASIS7_NEWAPI_BRIDGE_ROUTE_TTL_SECONDS=900
OASIS7_NEWAPI_BRIDGE_DEPOSIT_ACCOUNT_PREFIX=oc:bridge:
OASIS7_NEWAPI_BRIDGE_LETAI_BASE_URL=https://api.letai.run
OASIS7_NEWAPI_BRIDGE_LETAI_PLATFORM_KEY=replace-with-letai-platform-key
# Required for real ECS deployments so generated project tokens land in the intended LetAI channel.
OASIS7_NEWAPI_BRIDGE_LETAI_PARENT_CHANNEL_ID=replace-with-letai-parent-channel-id
OASIS7_NEWAPI_BRIDGE_LETAI_TIMEOUT_MS=5000
OASIS7_NEWAPI_BRIDGE_MAX_CREDIT_ATTEMPTS=3
OASIS7_NEWAPI_BRIDGE_RECONCILE_INTERVAL_SECONDS=0
OASIS7_NEWAPI_BRIDGE_CHAIN_BASE_URL=
OASIS7_NEWAPI_BRIDGE_CHAIN_TIMEOUT_MS=5000
OASIS7_NEWAPI_BRIDGE_CHAIN_CONFIRMATIONS_REQUIRED=1

# Minimal bind example:
# curl -sS -X POST http://127.0.0.1:5852/v1/bridge/bind \
#   -H 'Content-Type: application/json' \
#   -d '{"newapi_user_ref":"user-1","oasis_sender_account_id":"oc:pk:user-1"}'
